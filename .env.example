# Copy to .env and adjust. .env is gitignored — never commit real secrets.
FM_ADDR=:8080
FM_SOURCE_TIMEOUT=8s
FM_DEFAULT_CURRENCY=RUB
FM_CORS_ORIGIN=http://localhost:5173
FM_ENABLE_MOCK=true

